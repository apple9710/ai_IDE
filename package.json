{
  "name": "claude-ide",
  "version": "0.2.0",
  "description": "A lightweight VS Code-style IDE for using Claude Code",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable",
    "dist:installer": "electron-builder --win nsis"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.claudeide.app",
    "productName": "Claude IDE",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "docs/**/*",
      "!**/*.zip"
    ],
    "asarUnpack": [
      "node_modules/@lydell/node-pty/**",
      "node_modules/@anthropic-ai/claude-agent-sdk-*/**",
      "node_modules/@openai/codex-*/**"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "Claude-IDE-${version}-portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.198",
    "@lydell/node-pty": "^1.1.0",
    "@openai/codex-sdk": "^0.142.5",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "monaco-editor": "^0.52.2"
  }
}
